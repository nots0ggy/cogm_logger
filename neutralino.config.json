{
	"applicationId": "ikusa.logger",
	"version": "1.22.0",
	"defaultMode": "window",
	"documentRoot": "/ui/build/",
	"url": "/",
	"enableServer": true,
	"enableNativeAPI": true,
	"tokenSecurity": "none",
	"nativeAllowList": [
		"app.exit",
		"filesystem.readFile",
		"filesystem.writeFile",
		"filesystem.writeBinaryFile",
		"filesystem.createDirectory",
		"filesystem.remove",
		"filesystem.readDirectory",
		"filesystem.getStats",
		"os.open",
		"os.showOpenDialog",
		"os.showSaveDialog",
		"os.spawnProcess",
		"os.updateSpawnedProcess",
		"os.execCommand",
		"os.getPath",
		"os.getEnv",
		"clipboard.writeText",
		"storage.setData",
		"storage.getData"
	],
	"modes": {
		"window": {
			"title": "CoGM Logger",
			"width": 1120,
			"height": 740,
			"minWidth": 820,
			"minHeight": 600,
			"resizable": true,
			"icon": "/ui/static/logo.png",
			"exitProcessOnClose": false,
			"enableInspector": false
		}
	},
	"cli": {
		"binaryName": "cogm-logger",
		"resourcesPath": "/ui/build/",
		"extensionsPath": "/extensions/",
		"binaryVersion": "5.6.0",
		"clientVersion": "5.6.0",
		"frontendLibrary": {
			"patchFile": "/ui/src/app.html",
			"devUrl": "http://localhost:5173",
			"projectPath": "/ui/",
			"initCommand": "npm install",
			"devCommand": "npm run dev",
			"buildCommand": "npm run build"
		}
	}
}
